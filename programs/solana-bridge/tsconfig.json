{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "types": ["mocha", "chai"]
  },
  "include": ["tests/**/*.ts"]
}
